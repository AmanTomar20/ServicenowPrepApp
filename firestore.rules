rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // User progress rules
    match /users/{userId} {
      allow read, write: if true; 
      
      match /submissions/{submissionId} {
        allow read, write: if true;
      }
    }
  }
}
